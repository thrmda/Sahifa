        }
      }
    },
    "That path is not a folder.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا المسار ليس مجلدًا."
          }
        }
      }
    },
    "The server couldn't be reached. If you quit now, these changes are lost.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر الوصول إلى الخادم. إذا خرجت الآن، ستُفقد هذه التغييرات."
          }
        }
      }
    },
    "The token is kept in your Mac's Keychain.": {
      "localizations": {
        "ar": {
