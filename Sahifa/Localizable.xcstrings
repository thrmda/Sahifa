    },
    "Add a folder of Markdown files, or open a single file. Folders stay in the sidebar until you remove them.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف مجلدًا يحتوي على ملفات Markdown، أو افتح ملفًا مفردًا. تبقى المجلدات في الشريط الجانبي حتى تزيلها."
          }
        }
      }
    },
    "Bold": {
      "localizations": {
        "ar": {
